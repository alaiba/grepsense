# Copy to .env and edit. `docker compose` reads this automatically.

# REQUIRED: absolute path to the code you want indexed (a single git repo, or a
# directory containing several). Mounted read-only into the containers at /code.
GREPSENSE_TARGET=/absolute/path/to/your/project

# Port the MCP server (streamable-HTTP) is published on. Register this with your
# agent, e.g.  claude mcp add --transport http grepsense http://localhost:8765/mcp
GREPSENSE_HTTP_PORT=8765

# Semantic collection name (namespace your embeddings).
GREPSENSE_COLLECTION=grepsense

# Images. Defaults pull from GHCR; `docker compose build` builds locally instead.
ZOEKT_IMAGE=ghcr.io/alaiba/grepsense-zoekt:latest
GREPSENSE_IMAGE=ghcr.io/alaiba/grepsense:latest

# Named volumes for the engine indexes (override to run multiple stacks).
ZOEKT_VOLUME=grepsense-zoekt-index
CHROMADB_VOLUME=grepsense-chroma-data
