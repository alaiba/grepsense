# Zoekt engine configuration (used by docker-compose.yml).
ZOEKT_INDEX_DIR=/data/index
ZOEKT_HOST_PORT=6070

# Root of the code to index, as mounted inside the containers.
GREPSENSE_ROOT=/code

# Re-index interval in seconds (default: 300 = 5 minutes).
REINDEX_INTERVAL=300

# Max file size to index (bytes); skip large generated files.
ZOEKT_FILE_LIMIT=1048576

# Zoekt engine image. Pulled from GHCR by default; falls back to a local build.
ZOEKT_IMAGE=ghcr.io/alaiba/grepsense-zoekt:latest
